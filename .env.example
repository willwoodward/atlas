# Copy to .env for local dev, or .env.production on the droplet.
# Never commit either — they contain real secrets.

# Who is allowed to log in (comma-separated Google emails)
ALLOWED_EMAILS=will@woodwardweb.com

# CORS: origins allowed to call the API
# Local:      http://localhost:5173
# Production: https://<github-username>.github.io
ALLOWED_ORIGINS=http://localhost:5173

# Your Google OAuth client ID (same one used for Google Calendar)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# JWT signing secret — generate: openssl rand -hex 32
JWT_SECRET=replace_with_64_random_chars

# MCP API key — generate: openssl rand -hex 16
ATLAS_MCP_KEY=replace_with_32_random_chars

# SQLite file path inside the container
DATABASE_PATH=/data/atlas.db
